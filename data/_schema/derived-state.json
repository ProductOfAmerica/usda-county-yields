{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdn.jsdelivr.net/gh/ProductOfAmerica/usda-county-yields@main/data/_schema/derived-state.json",
  "title": "NASS derived per-state shard (v3)",
  "description": "Per-(state, crop) production-weighted yield (state and national, sum production / sum area harvested) plus a county comparison scan (each county's canonical yield and within-state/within-nation rank). The national block is identical across every state file for a given crop.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "state", "commodity", "production_weighted_yield", "counties"],
  "properties": {
    "schema_version": {"const": 3},
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fips", "alpha", "name"],
      "properties": {
        "fips": {"type": "string", "pattern": "^[0-9]{2}$"},
        "alpha": {"type": "string", "pattern": "^[A-Z]{2}$"},
        "name": {"type": "string"}
      }
    },
    "commodity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "desc"],
      "properties": {"slug": {"type": "string"}, "desc": {"type": "string"}}
    },
    "production_weighted_yield": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "national"],
      "properties": {
        "state": {"type": "object", "additionalProperties": {"type": "number"}},
        "national": {"type": "object", "additionalProperties": {"type": "number"}}
      }
    },
    "counties": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "yield", "rank"],
        "properties": {
          "name": {"type": "string"},
          "yield": {"type": "object", "additionalProperties": {"type": "number"}},
          "rank": {"type": "object"}
        }
      }
    }
  }
}
